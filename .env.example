# Yandex Maps API Configuration
# 
# Copy this file to .env and fill in your actual API keys from Yandex Maps
# The .env file will be automatically loaded when you run npm start or npm build
#
# Get your API keys from: https://developer.tech.yandex.com/services/api/maps/

YANDEX_MAPS_API_KEY=your_api_key_here
YANDEX_MAPS_SUGGEST_API_KEY=your_suggest_api_key_here
